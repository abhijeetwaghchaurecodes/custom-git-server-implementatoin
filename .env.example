# ═══════════════════════════════════════════════════════════════════════════════
# SEBI MF Backend — CI/CD Pipeline Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then source it before running the pipeline:
#   source .env
#   ./pipeline.sh --auto
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── GitHub Configuration (Required) ─────────────────────────────────────────
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: repo, write:packages, read:packages, delete:packages

export GITHUB_USERNAME="your-github-username"
export GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"
export GITHUB_REPO_URL="https://github.com/your-github-username/sebi-mf-backend.git"

# ─── Docker Image Configuration (Optional — defaults shown) ──────────────────

export IMAGE_NAME="sebi-mf-backend"
export IMAGE_TAG="latest"
export HOST_PORT="8080"

# ─── DevOps Agent LLM Configuration (for agent-driven pipeline) ──────────────
# Only needed if driving the pipeline through the DevOps Pipeline Agent UI
# instead of the pipeline.sh script.

# export LLM_API_URL="https://integrate.api.nvidia.com/v1/chat/completions"
# export LLM_API_KEY="your-nvidia-api-key"
# export LLM_MODEL="qwen/qwen3-32b"